# Optional (but recommended for real live data):
# Foursquare Places API — free tier, 1000 calls/day — https://developer.foursquare.com
# Without this key, the app uses rich curated city data (works great out of the box).
FOURSQUARE_API_KEY=

# Optional: App URL (auto-set on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
